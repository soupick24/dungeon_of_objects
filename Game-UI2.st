Object subclass: #GameWidget	instanceVariableNames: 'x y height width'	classVariableNames: ''	poolDictionaries: ''	category: 'Game-UI'!!GameWidget commentStamp: 'r 7/11/2026 15:46' prior: 0!An abstract class is a "foundation."!!GameWidget methodsFor: 'as yet unclassified' stamp: 'r 7/11/2026 13:53'!drawOn: aCanvas    aCanvas frameRectangle: (x @ y extent: width @ height)            color: Color black.! !!GameWidget methodsFor: 'as yet unclassified' stamp: 'r 7/11/2026 11:35'!initialize    super initialize.    x := 0.    y := 0.    width := 100.    height := 50.! !!GameWidget methodsFor: 'as yet unclassified' stamp: 'r 7/11/2026 15:51'!update! !!GameWidget methodsFor: 'accessing' stamp: 'r 7/11/2026 14:22'!bounds    ^ x @ y extent: width @ height! !!GameWidget methodsFor: 'accessing' stamp: 'r 7/11/2026 14:10'!height: anInteger 	height := anInteger! !!GameWidget methodsFor: 'accessing' stamp: 'r 7/11/2026 14:09'!width: anInteger 	width := anInteger! !!GameWidget methodsFor: 'accessing' stamp: 'r 7/11/2026 14:06'!x: anInteger 	x := anInteger	! !!GameWidget methodsFor: 'фс' stamp: 'r 7/11/2026 14:08'!y: anInteger 	y := anInteger! !!GameWidget methodsFor: 'geometry' stamp: 'r 7/11/2026 16:32'!containsPoint: aPoint    ^ self bounds containsPoint: aPoint! !GameWidget subclass: #ContainerWidget	instanceVariableNames: 'children'	classVariableNames: ''	poolDictionaries: ''	category: 'Game-UI'!!ContainerWidget commentStamp: 'r 7/11/2026 15:23' prior: 0!Knows how to support others!!ContainerWidget methodsFor: 'as yet unclassified' stamp: 'r 7/11/2026 13:45'!addChild: aWidget    children add: aWidget.! !!ContainerWidget methodsFor: 'as yet unclassified' stamp: 'r 7/11/2026 14:20'!drawOn: aCanvas    aCanvas fillRectangle: (self bounds) color: Color lightBlue.     super drawOn: aCanvas.    children do: [ :each | each drawOn: aCanvas ].! !!ContainerWidget methodsFor: 'as yet unclassified' stamp: 'r 7/11/2026 13:22'!initialize     super initialize.     children := OrderedCollection new.! !GameWidget subclass: #GameButton	instanceVariableNames: 'label action'	classVariableNames: ''	poolDictionaries: ''	category: 'Game-UI'!!GameButton commentStamp: 'r 7/11/2026 15:23' prior: 0!It can respond to presses.!!GameButton methodsFor: 'as yet unclassified' stamp: 'r 7/11/2026 11:39'!initialize    super initialize.    label := 'Click Me!!'.! !GameWidget subclass: #GameLabel	instanceVariableNames: 'text'	classVariableNames: ''	poolDictionaries: ''	category: 'Game-UI'!!GameLabel commentStamp: 'r 7/11/2026 15:24' prior: 0!Can display text!GameWidget subclass: #GamePanel	instanceVariableNames: ''	classVariableNames: ''	poolDictionaries: ''	category: 'Game-UI'!!GamePanel commentStamp: 'r 7/11/2026 15:24' prior: 0!Can draw backgrounds/frames.!ContainerWidget subclass: #GameWorld	instanceVariableNames: ''	classVariableNames: ''	poolDictionaries: ''	category: 'Game-UI'!!GameWorld methodsFor: 'as yet unclassified' stamp: 'r 7/11/2026 16:34'!handleMouseUp: aPoint    (self containsPoint: aPoint) ifTrue: [        Transcript show: 'The button has been pressed'; cr.    ]! !